# Copy this file to .env and fill in your values.
# NEVER commit the .env file — it is in .gitignore.

# Private key of the deployer account (hex, without 0x prefix).
DEPLOYER_PRIVATE_KEY=

# Infura project ID for Sepolia / mainnet RPC access.
INFURA_PROJECT_ID=

# Etherscan API key for automatic source verification.
ETHERSCAN_API_KEY=

# Override the token address (defaults to the known USDC address for the network).
# Sepolia USDC:  0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
# Mainnet USDC:  0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
# USDC_TOKEN_ADDRESS=

# Set to any non-empty value to enable gas reporting.
# REPORT_GAS=1
